# GoatedBuy · production env template.
# Copy to `.env` at the repo root (gitignored) on the server and fill everything in.
# Keep POSTGRES_PASSWORD identical to the password inside DATABASE_URL.

# --- Postgres (db service + DATABASE_URL below must match) -------------------
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Backend runtime --------------------------------------------------------
DATABASE_URL=postgres://goatedbuy:CHANGE_ME_strong_db_password@db:5432/goatedbuy
REDIS_URL=redis://redis:6379
CORS_ALLOWED_ORIGINS=https://goated-buy.us,https://www.goated-buy.us,https://ops.goated-buy.us
STORAGE_PUBLIC_BASE_URL=https://api.goated-buy.us

# --- Secrets — generate each with:  openssl rand -hex 32 --------------------
AUTH_DEVICE_HMAC_SECRET=CHANGE_ME
AUTH_TOTP_ENCRYPTION_SECRET=CHANGE_ME
ACCOUNT_ADDRESS_HMAC_SECRET=CHANGE_ME
STORAGE_SIGNING_SECRET=CHANGE_ME
SHIPPING_WEBHOOK_SECRET=CHANGE_ME
AUTH_TOTP_ISSUER=GoatedBuy

# NOTE: the dev admin-MFA bypass is force-OFF when NODE_ENV=production (set in
# docker-compose.prod.yml), so admin login uses real TOTP 2FA in production.
