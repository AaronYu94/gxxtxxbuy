# Copy this file to .env for local development. Values here are placeholders only.
NODE_ENV=development
SERVICE_NAME=goatedbuy-backend
APP_VERSION=0.1.0
PORT=3000
REQUEST_LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
STORAGE_DRIVER=local
STORAGE_BUCKET=goatedbuy-local-private
STORAGE_LOCAL_DIR=.data/storage
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:3000
STORAGE_SIGNING_SECRET=local-dev-storage-signing-secret
STORAGE_SIGNED_URL_TTL_SECONDS=900
SHIPPING_QUOTE_TTL_SECONDS=900
SHIPPING_WEBHOOK_SECRET=local-dev-shipping-webhook-secret
WELCOME_GIFT_ENABLED=true
WELCOME_GIFT_CODE=WELCOME10
WELCOME_GIFT_AMOUNT_CENTS=1000

# Risk automation (B7). Disabled by default so it never opens cases without opt-in.
RISK_COUPON_ABUSE_ENABLED=false
RISK_COUPON_ABUSE_THRESHOLD=5

# Feature flags / canary kill switches (B8-07). Turn a surface off without a deploy.
FEATURE_PAYMENTS_ENABLED=true
FEATURE_SHIPPING_ENABLED=true
FEATURE_COUPONS_ENABLED=true
FEATURE_CREATORS_ENABLED=true

# Local Docker Compose defaults. The service can start without these, but /ready will fail.
DATABASE_URL=postgres://goatedbuy:goatedbuy_dev_password@127.0.0.1:5433/goatedbuy
DB_POOL_MAX=5
DB_CONNECTION_TIMEOUT_MS=1500
DB_IDLE_TIMEOUT_MS=10000

REDIS_URL=redis://127.0.0.1:6380
REDIS_CONNECT_TIMEOUT_MS=1500

READY_REQUIRES_DATABASE=true
READY_REQUIRES_REDIS=true
