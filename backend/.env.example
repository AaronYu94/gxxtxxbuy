# Copy this file to .env for local development. Values here are placeholders only.
NODE_ENV=development
SERVICE_NAME=goatedbuy-backend
APP_VERSION=0.1.0
PORT=3000
REQUEST_LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
STORAGE_DRIVER=local
STORAGE_BUCKET=goatedbuy-local-private
STORAGE_LOCAL_DIR=.data/storage
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:3000
STORAGE_SIGNING_SECRET=local-dev-storage-signing-secret
STORAGE_SIGNED_URL_TTL_SECONDS=900
SHIPPING_QUOTE_TTL_SECONDS=900
SHIPPING_WEBHOOK_SECRET=local-dev-shipping-webhook-secret
WELCOME_GIFT_ENABLED=true
WELCOME_GIFT_CODE=WELCOME10
WELCOME_GIFT_AMOUNT_CENTS=1000

# Link parsing. Inline resolves pasted links immediately (demo/dev, no Redis needed).
# In production leave this false and run `npm run worker:parse` against the links:parse queue.
LINK_PARSE_INLINE=false

# Catalog parsing (V2-03). The approved marketplace data source is a pending
# business decision (GB-DEC-P0-004); until it lands, keep this "not_configured"
# and every adapter degrades to manual completion — never fabricated supplier data.
# Run `npm run worker:catalog-parse` against the catalog:parse queue in production.
PRODUCT_SOURCE_PROVIDER=not_configured
CATALOG_PARSE_MAX_ATTEMPTS=5
CATALOG_PARSE_BACKOFF_BASE_MS=2000
CATALOG_PARSE_BACKOFF_MAX_MS=300000

# Risk automation (B7). Disabled by default so it never opens cases without opt-in.
RISK_COUPON_ABUSE_ENABLED=false
RISK_COUPON_ABUSE_THRESHOLD=5

# Feature flags / canary kill switches. Turn a surface off without a deploy.
FEATURE_PAYMENTS_ENABLED=true
FEATURE_SHIPPING_ENABLED=true
FEATURE_COUPONS_ENABLED=true
FEATURE_CREATORS_ENABLED=true

# Local Docker Compose defaults. The service can start without these, but /ready will fail.
DATABASE_URL=postgres://goatedbuy:goatedbuy_dev_password@127.0.0.1:5433/goatedbuy
DB_POOL_MAX=5
DB_CONNECTION_TIMEOUT_MS=1500
DB_IDLE_TIMEOUT_MS=10000

REDIS_URL=redis://127.0.0.1:6380
REDIS_CONNECT_TIMEOUT_MS=1500

READY_REQUIRES_DATABASE=true
READY_REQUIRES_REDIS=true
# Identity and MFA security (replace all secrets outside local development)
AUTH_VERIFICATION_TTL_SECONDS=1800
AUTH_VERIFICATION_RESEND_SECONDS=60
AUTH_DEVICE_REVERIFY_DAYS=7
AUTH_LOGIN_FAILURE_LIMIT=5
AUTH_LOGIN_FAILURE_WINDOW_SECONDS=900
AUTH_SECURITY_LOCK_SECONDS=86400
AUTH_DEVICE_HMAC_SECRET=replace-with-a-long-random-secret
AUTH_TOTP_ENCRYPTION_SECRET=replace-with-a-different-long-random-secret
AUTH_TOTP_ISSUER=GoatedBuy
AUTH_ADMIN_CHALLENGE_TTL_SECONDS=300
AUTH_REAUTH_TTL_SECONDS=300
AUTH_ADMIN_ABSOLUTE_SESSION_HOURS=24
AUTH_EXPOSE_VERIFICATION_TOKEN=false
ACCOUNT_ADDRESS_HMAC_SECRET=replace-with-an-independent-long-random-secret
ACCOUNT_DELETION_POLL_MS=5000
